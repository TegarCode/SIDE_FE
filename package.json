{
  "name": "frontend-typescript-boilerplate",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "dev:full": "concurrently \"npm:dev\" \"npm:type-check:watch\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": "prettier --write"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/file-saver": "^2.0.7",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.35.0",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-globe.gl": "^2.37.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "react-select": "^5.10.2",
    "recharts": "^3.8.0",
    "three": "^0.183.2",
    "xlsx-js-style": "^1.2.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
